		"@storybook/addon-a11y": "^10.5.3",
		"@storybook/react-vite": "^10.5.3",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"storybook": "^10.5.3",
		"tslib": "^2.8.1",
		"typescript": "^7.0.2",
		"vite": "^8.1.5"
	}
