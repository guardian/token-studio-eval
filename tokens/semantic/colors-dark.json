{
  "semantic": {
    "colors": {
      "bg": {
        "base": {
          "$value": "{base.colors.neutral.100}",
          "$type": "color",
          "$description": "this should be the primary background colour for most applications"
        }
      },
      "border": {
        "accent": {
          "$value": "{base.colors.red.800}",
          "$type": "color"
        },
        "focused": {
          "$value": "{base.colors.red.600}",
          "$type": "color"
        }
      },
      "fill": {
        "accentStrong": {
          "$value": "{base.colors.red.800}",
          "$type": "color"
        },
        "accentStrongHover": {
          "$value": "{base.colors.red.900}",
          "$type": "color"
        }
      },
      "text": {
        "strong": {
          "$value": "{base.colors.neutral.900}",
          "$type": "color",
          "$extensions": {
            "com.figma": {
              "scopes": [
                "ALL_SCOPES"
              ],
              "codeSyntax": {},
              "hiddenFromPublishing": false
            }
          }
        },
        "strongInverse": {
          "$value": "{base.colors.neutral.300}",
          "$type": "color"
        },
        "strongerInverse": {
          "$value": "{base.colors.neutral.0}",
          "$type": "color"
        },
        "success": {
          "$value": "{base.colors.green.800}",
          "$type": "color"
        },
        "successInverse": {
          "$value": "{base.colors.green.200}",
          "$type": "color"
        }
      }
    }
  }
}